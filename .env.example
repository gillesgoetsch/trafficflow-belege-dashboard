# =============================================================================
# Belege-Hub Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- App ---
APP_ENV=production
APP_NAME=Belege-Hub
APP_BASE_URL=https://belege.trafficflow.ch
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Secrets (CHANGE BEFORE DEPLOY!) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

# --- Initial admin user (created on first boot) ---
ADMIN_EMAIL=gilles@trafficflow.ch
ADMIN_PASSWORD=change-me-strong-password

# --- Database ---
POSTGRES_USER=belege
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=belege
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://belege:change-me-db-password@db:5432/belege

# --- Redis (broker for ARQ) ---
REDIS_URL=redis://redis:6379/0

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
OCR_MODEL=claude-sonnet-4-6

# --- IMAP defaults ---
IMAP_BATCH_INTERVAL_MINUTES=30

# --- Storage ---
STORAGE_PATH=/data/receipts

# --- OneDrive (per-connector config in DB, these are app-wide OAuth client) ---
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=https://belege.trafficflow.ch/api/connectors/onedrive/callback

# --- Bexio ---
# Per-connector tokens stored in DB. No app-wide config needed.

# --- Deploy webhook ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEPLOY_WEBHOOK_SECRET=change-me-github-webhook-secret
DEPLOY_BRANCH=main
DEPLOY_REPO_PATH=/srv/belege
# Host dir containing id_ed25519 (private key) for the GitHub deploy key.
# Used by the webhook container to git fetch a private repo.
DEPLOY_SSH_DIR=/srv/belege-deploy-ssh

# --- Backups (optional, S3-compatible) ---
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_REGION=auto

# --- Caddy / TLS ---
DOMAIN=belege.trafficflow.ch
ACME_EMAIL=gilles@trafficflow.ch
